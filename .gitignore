# =============================================================================
# GIT IGNORE
# Everything generated. If it can be rebuilt, it does not belong in git.
# -----------------------------------------------------------------------------
# NOTE: Lockfiles are the deliberate exception — package-lock.json and
#   swift/Package.resolved ARE committed so builds are reproducible.
# WARN: git has no inline comments; a trailing `# ...` becomes part of the
#   pattern and silently matches nothing. Keep comments on their own line.
# =============================================================================

# --- Dependencies ------------------------------------------------------------
node_modules/

# --- Raycast: generated by `ray build` (raycast-env.d.ts holds Preferences) ---
raycast-env.d.ts
compiled_raycast_swift/
dist/

# --- Swift / SwiftPM: build artifacts (Package.resolved IS committed) --------
swift/.build/
swift/.swiftpm/
swift/.raycast-swift-build/

# --- Tests: tsc output the unit tests run against ----------------------------
.test-build/

# --- macOS -------------------------------------------------------------------
.DS_Store
